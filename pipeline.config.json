{
  "projectName": "ai-web-scraping-pipeline",
  "recordType": "use_case",
  "domainDescription": "Public examples of enterprise AI deployments and implementation patterns.",
  "sourceDiscovery": {
    "seedUrls": [],
    "searchProvider": "none",
    "searchQueries": [],
    "searchMaxResults": 10,
    "googleApiKeyEnv": "GOOGLE_SEARCH_API_KEY",
    "googleSearchEngineIdEnv": "GOOGLE_SEARCH_ENGINE_ID",
    "allowedDomains": [],
    "blockedDomains": [],
    "revisitFrequencyDays": 14,
    "maxLinksPerSource": 25
  },
  "schema": {
    "fields": [
      { "name": "title", "type": "string", "required": true },
      { "name": "organization", "type": "string", "required": false },
      { "name": "summary", "type": "string", "required": true },
      { "name": "sourceUrl", "type": "string", "required": true },
      { "name": "useCaseType", "type": "string", "required": false },
      { "name": "industry", "type": "string", "required": false },
      { "name": "technologies", "type": "array", "required": false }
    ]
  },
  "llm": {
    "provider": "azure-openai",
    "deploymentNameEnv": "AZURE_OPENAI_DEPLOYMENT",
    "maxInputChars": 18000,
    "temperature": 0.1
  },
  "embedding": {
    "enabled": true,
    "deploymentNameEnv": "AZURE_OPENAI_EMBEDDING_DEPLOYMENT",
    "profile": "provider-neutral-v1",
    "dimensions": 3072,
    "maxInputChars": 8000
  },
  "groundedness": {
    "enabled": true,
    "deploymentNameEnv": "AZURE_OPENAI_GROUNDEDNESS_DEPLOYMENT",
    "maxInputChars": 18000,
    "threshold": 3.0,
    "requirePass": false
  },
  "prompts": {
    "extractionSystem": "prompts/extraction.system.md",
    "extractionUser": "prompts/extraction.user.md",
    "groundednessSystem": "prompts/groundedness.system.md",
    "groundednessUser": "prompts/groundedness.user.md"
  },
  "quality": {
    "requireSourceEvidence": true,
    "reviewBeforeStore": true,
    "duplicateDetection": true,
    "duplicateSimilarityThreshold": 0.85,
    "duplicateConfidenceThreshold": 0.9,
    "duplicateCandidateLimit": 8
  },
  "allowDeterministicFallbackForSmokeTests": false
}
