{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "5613616054997598587"
    }
  },
  "parameters": {
    "environmentName": {
      "type": "string",
      "metadata": {
        "description": "Environment name used as a suffix for resource names."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    },
    "createAzureAI": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Create an Azure AI Services resource for Microsoft Foundry / Azure OpenAI compatible model deployments."
      }
    },
    "azureOpenAIDeployment": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Azure OpenAI / Foundry chat model deployment name for structured extraction. Leave empty only while provisioning resources before model setup."
      }
    },
    "azureOpenAIEmbeddingDeployment": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Azure OpenAI embedding deployment name used for embedding-based duplicate detection. Leave empty only while provisioning resources before model setup."
      }
    },
    "azureOpenAIGroundednessDeployment": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Azure OpenAI / Foundry model deployment name used for groundedness checks. Leave empty only while provisioning resources before model setup."
      }
    },
    "azureAIProjectEndpoint": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional Microsoft Foundry project endpoint used by Microsoft Agent Framework chat calls. Example: https://<account>.services.ai.azure.com/api/projects/<project>."
      }
    },
    "embeddingDimensions": {
      "type": "int",
      "defaultValue": 3072,
      "minValue": 1,
      "metadata": {
        "description": "Embedding dimensions for the Records container vector policy. Match the configured embedding model deployment."
      }
    }
  },
  "variables": {
    "normalizedName": "[toLower(replace(parameters('environmentName'), '-', ''))]",
    "unique": "[uniqueString(resourceGroup().id, parameters('environmentName'))]",
    "storageName": "[take(format('st{0}{1}', variables('normalizedName'), variables('unique')), 24)]",
    "appInsightsName": "[format('appi-{0}', parameters('environmentName'))]",
    "workspaceName": "[format('log-{0}', parameters('environmentName'))]",
    "cosmosName": "[format('cosmos-{0}-{1}', parameters('environmentName'), take(variables('unique'), 6))]",
    "aiServicesName": "[take(format('ai-{0}-{1}', parameters('environmentName'), take(variables('unique'), 6)), 64)]",
    "planName": "[format('plan-{0}', parameters('environmentName'))]",
    "functionName": "[format('func-{0}-{1}', parameters('environmentName'), take(variables('unique'), 6))]",
    "databaseName": "explorative-pipeline",
    "containers": [
      {
        "name": "PipelineConfig",
        "pk": "/PartitionKey"
      },
      {
        "name": "SourcePageRegistry",
        "pk": "/pk"
      },
      {
        "name": "CandidateQueue",
        "pk": "/PartitionKey"
      },
      {
        "name": "ReviewQueue",
        "pk": "/PartitionKey"
      },
      {
        "name": "PipelineRuns",
        "pk": "/PartitionKey"
      },
      {
        "name": "TokenUsage",
        "pk": "/agentName"
      }
    ]
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('storageName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "allowBlobPublicAccess": false,
        "minimumTlsVersion": "TLS1_2"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}', variables('storageName'), 'default')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}/{2}', variables('storageName'), 'default', 'app-package')]",
      "properties": {
        "publicAccess": "None"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('storageName'), 'default')]"
      ]
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('workspaceName')]",
      "location": "[parameters('location')]",
      "properties": {
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('appInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName'))]"
      ]
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts",
      "apiVersion": "2024-05-15",
      "name": "[variables('cosmosName')]",
      "location": "[parameters('location')]",
      "kind": "GlobalDocumentDB",
      "properties": {
        "databaseAccountOfferType": "Standard",
        "capabilities": [
          {
            "name": "EnableNoSQLVectorSearch"
          }
        ],
        "consistencyPolicy": {
          "defaultConsistencyLevel": "Session"
        },
        "locations": [
          {
            "locationName": "[parameters('location')]",
            "failoverPriority": 0,
            "isZoneRedundant": false
          }
        ]
      }
    },
    {
      "condition": "[parameters('createAzureAI')]",
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2024-10-01",
      "name": "[variables('aiServicesName')]",
      "location": "[parameters('location')]",
      "kind": "AIServices",
      "sku": {
        "name": "S0"
      },
      "properties": {
        "customSubDomainName": "[variables('aiServicesName')]",
        "publicNetworkAccess": "Enabled"
      }
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases",
      "apiVersion": "2024-05-15",
      "name": "[format('{0}/{1}', variables('cosmosName'), variables('databaseName'))]",
      "properties": {
        "resource": {
          "id": "[variables('databaseName')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosName'))]"
      ]
    },
    {
      "copy": {
        "name": "sqlContainers",
        "count": "[length(variables('containers'))]"
      },
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases/containers",
      "apiVersion": "2024-05-15",
      "name": "[format('{0}/{1}/{2}', variables('cosmosName'), variables('databaseName'), variables('containers')[copyIndex()].name)]",
      "properties": {
        "resource": {
          "id": "[variables('containers')[copyIndex()].name]",
          "partitionKey": {
            "paths": [
              "[variables('containers')[copyIndex()].pk]"
            ],
            "kind": "Hash"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts/sqlDatabases', variables('cosmosName'), variables('databaseName'))]"
      ]
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases/containers",
      "apiVersion": "2024-05-15",
      "name": "[format('{0}/{1}/{2}', variables('cosmosName'), variables('databaseName'), 'Records')]",
      "properties": {
        "resource": {
          "id": "Records",
          "partitionKey": {
            "paths": [
              "/PartitionKey"
            ],
            "kind": "Hash"
          },
          "vectorEmbeddingPolicy": {
            "vectorEmbeddings": [
              {
                "path": "/embedding",
                "dataType": "float32",
                "distanceFunction": "cosine",
                "dimensions": "[parameters('embeddingDimensions')]"
              }
            ]
          },
          "indexingPolicy": {
            "indexingMode": "consistent",
            "automatic": true,
            "includedPaths": [
              {
                "path": "/*"
              }
            ],
            "excludedPaths": [
              {
                "path": "/\"_etag\"/?"
              },
              {
                "path": "/embedding/*"
              }
            ],
            "vectorIndexes": [
              {
                "path": "/embedding",
                "type": "quantizedFlat"
              }
            ]
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts/sqlDatabases', variables('cosmosName'), variables('databaseName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2024-04-01",
      "name": "[variables('planName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp",
      "sku": {
        "name": "FC1",
        "tier": "FlexConsumption"
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2024-04-01",
      "name": "[variables('functionName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "httpsOnly": true,
        "functionAppConfig": {
          "runtime": {
            "name": "python",
            "version": "3.11"
          },
          "scaleAndConcurrency": {
            "maximumInstanceCount": 20,
            "instanceMemoryMB": 2048
          },
          "deployment": {
            "storage": {
              "type": "blobContainer",
              "value": "[format('{0}app-package', reference(resourceId('Microsoft.Storage/storageAccounts', variables('storageName')), '2023-05-01').primaryEndpoints.blob)]",
              "authentication": {
                "type": "StorageAccountConnectionString",
                "storageAccountConnectionStringName": "AzureWebJobsStorage"
              }
            }
          }
        },
        "siteConfig": {
          "appSettings": "[concat(createArray(createObject('name', 'AzureWebJobsStorage', 'value', format('DefaultEndpointsProtocol=https;AccountName={0};EndpointSuffix={1};AccountKey={2}', variables('storageName'), environment().suffixes.storage, listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageName')), '2023-05-01').keys[0].value)), createObject('name', 'FUNCTIONS_EXTENSION_VERSION', 'value', '~4'), createObject('name', 'APPLICATIONINSIGHTS_CONNECTION_STRING', 'value', reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString), createObject('name', 'COSMOS_DATABASE_NAME', 'value', variables('databaseName')), createObject('name', 'CosmosDBConnection', 'value', listConnectionStrings(resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosName')), '2024-05-15').connectionStrings[0].connectionString), createObject('name', 'PIPELINE_CONFIG_PATH', 'value', 'pipeline.config.json'), createObject('name', 'SOURCE_REFRESH_CRON', 'value', '0 0 3 * * *'), createObject('name', 'MAX_LINKS_PER_SOURCE', 'value', '25'), createObject('name', 'AZURE_OPENAI_ENDPOINT', 'value', if(parameters('createAzureAI'), reference(resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName')), '2024-10-01').endpoint, '')), createObject('name', 'AZURE_OPENAI_DEPLOYMENT', 'value', parameters('azureOpenAIDeployment')), createObject('name', 'AZURE_OPENAI_EMBEDDING_DEPLOYMENT', 'value', parameters('azureOpenAIEmbeddingDeployment')), createObject('name', 'AZURE_OPENAI_GROUNDEDNESS_DEPLOYMENT', 'value', parameters('azureOpenAIGroundednessDeployment'))), if(empty(parameters('azureAIProjectEndpoint')), createArray(), createArray(createObject('name', 'AZURE_AI_PROJECT_ENDPOINT', 'value', parameters('azureAIProjectEndpoint')))))]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName'))]",
        "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]",
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices/containers', variables('storageName'), 'default', 'app-package')]",
        "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]"
      ]
    }
  ],
  "outputs": {
    "AZURE_FUNCTION_NAME": {
      "type": "string",
      "value": "[variables('functionName')]"
    },
    "AZURE_FUNCTION_URI": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', variables('functionName')), '2024-04-01').defaultHostName)]"
    },
    "COSMOS_ACCOUNT_NAME": {
      "type": "string",
      "value": "[variables('cosmosName')]"
    },
    "AZURE_AI_SERVICES_NAME": {
      "type": "string",
      "value": "[if(parameters('createAzureAI'), variables('aiServicesName'), '')]"
    },
    "AZURE_AI_SERVICES_ENDPOINT": {
      "type": "string",
      "value": "[if(parameters('createAzureAI'), reference(resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName')), '2024-10-01').endpoint, '')]"
    }
  }
}